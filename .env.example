# AWS Bedrock (Seoul region) — required
# Choose ONE of the following authentication methods:
#
# Option A: Named AWS profile (recommended)
AWS_PROFILE=your-profile-name
AWS_REGION=ap-northeast-2
#
# Option B: Static credentials (not recommended — prefer profiles or SSO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Bedrock model for all text/reasoning agents
# Seoul region supports Claude Sonnet 4.6 via the "global" cross-region
# inference profile. Override if you have direct access to a regional model.
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# Where generated Markdown prompts are written
OUTPUT_DIR=./outputs
